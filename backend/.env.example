# ============================================================
# FlashChat Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# SECRETS MUST BE ROTATED IF EVER EXPOSED.
# ============================================================

NODE_ENV=development
PORT=3001

# --- Database ---
# MongoDB Atlas connection string (replace with your cluster)
MONGODB_URI=mongodb://localhost:27017/flashchat

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT (MUST be unique, cryptographically random, ≥32 chars) ---
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Google OAuth ---
# Get from Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# --- Cloudinary ---
# Get from Cloudinary Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Frontend URL (for CORS & OAuth redirect) ---
CLIENT_URL=http://localhost:3000

# --- Rate Limiting ---
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --- AI Providers (optional — app runs in mock mode without these) ---
# Get from respective provider dashboards
OPENROUTER_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=